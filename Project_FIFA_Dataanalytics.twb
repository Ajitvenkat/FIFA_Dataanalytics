      <column aggregation='None' caption='Age (bin)' datatype='integer' name='[Age (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[Age]' peg='0' size='3' />
      </column>
      <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
      <column caption='Ball Control' datatype='integer' name='[BallControl]' role='measure' type='quantitative' />
      <column datatype='string' name='[Body Type]' role='dimension' type='nominal' />
      <column caption='Total Players' datatype='integer' name='[Calculation_0223531614445568]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='count([Name])' />
      </column>
      <column caption='Average Overall Rating' datatype='real' name='[Calculation_0223531614728193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Overall])' />
      </column>
      <column caption='Total Market Value' datatype='real' name='[Calculation_0223531614851074]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1296929096204288])' />
      </column>
      <column caption='Total Wage' datatype='integer' name='[Calculation_0223531614949379]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Wage])' />
      </column>
      <column caption='Value new data' datatype='real' name='[Calculation_1296929096204288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND((POWER([Overall],3)) * 1000 * (1 - ABS([Age]-27)/20))' />
      </column>
      <column caption='Potential difference' datatype='integer' name='[Calculation_1296929147260929]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Potential]-[Overall]' />
      </column>
      <column caption='Age group' datatype='string' name='[Calculation_1296929150656514]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 23 THEN &quot;Young&quot;&#13;&#10;ELSEIF [Age] &lt; 30 THEN &quot;Prime&quot;&#13;&#10;ELSE &quot;Veteran&quot;&#13;&#10;END' />
      </column>
      <column caption='Contract Length' datatype='integer' name='[Calculation_1307924597096449]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1307924602105858] - 2018' />
      </column>
      <column caption='Contract Year' datatype='integer' name='[Calculation_1307924602105858]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISDATE(STR([Contract Valid Until])) THEN&#13;&#10;    YEAR(DATE(STR([Contract Valid Until])))&#13;&#10;ELSE&#13;&#10;    INT([Contract Valid Until])&#13;&#10;END' />
      </column>
